diff --git a/pty.c b/pty.c
index 6791fd5..47c7cb8 100644
--- a/pty.c
+++ b/pty.c
@@ -44,8 +44,12 @@
 
 /* for solaris 2.1, Unixware (SVR4.2) and possibly others */
 #ifdef HAVE_STROPTS_H
+#ifdef __MVS__
+# include <stropts.h>
+#else
 # include <sys/stropts.h>
 #endif
+#endif
 
 #if defined(sun) && defined(LOCKPTY) && !defined(TIOCEXCL)
 # include <sys/ttold.h>
@@ -67,17 +71,32 @@
  * if no PTYRANGE[01] is in the config file, we pick a default
  */
 #ifndef PTYRANGE0
+#ifdef __MVS__
+# define PTYRANGE0 "0123456789"
+#else
 # define PTYRANGE0 "qpr"
 #endif
+#endif
 #ifndef PTYRANGE1
+#ifdef __MVS__
+# define PTYRANGE1 "0123456789"
+#else
 # define PTYRANGE1 "0123456789abcdef"
 #endif
+#endif
+#ifdef __MVS__
+# define PTYRANGE2 "0123456789"
+#endif
 
 /* SVR4 pseudo ttys don't seem to work with SCO-5 */
 #ifdef M_UNIX
 # undef HAVE_SVR4_PTYS
 #endif
 
+#ifdef __MVS__
+#include <pty.h>
+#endif
+
 extern int eff_uid;
 
 /* used for opening a new pty-pair: */
@@ -91,6 +110,9 @@ static char TtyProto[] = "/dev/pty/ttyXY";
 #  ifdef M_UNIX
 static char PtyProto[] = "/dev/ptypXY";
 static char TtyProto[] = "/dev/ttypXY";
+#  elif defined(__MVS__)
+static char PtyProto[] = "/dev/ptyp0XYZ";
+static char TtyProto[] = "/dev/ttyp0XYZ";
 #  else
 static char PtyProto[] = "/dev/ptyXY";
 static char TtyProto[] = "/dev/ttyXY";
@@ -352,7 +374,7 @@ int
 OpenPTY(ttyn)
 char **ttyn;
 {
-  register char *p, *q, *l, *d;
+  register char *p, *q, *l, *d, *r;
   register int f;
 
   debug("OpenPTY: Using BSD style ptys.\n");
@@ -365,12 +387,15 @@ char **ttyn;
   for (l = PTYRANGE0; (*p = *l) != '\0'; l++)
     {
       for (d = PTYRANGE1; (p[1] = *d) != '\0'; d++)
+	{
+      for (r = PTYRANGE2; (p[2] = *r) != '\0'; r++)
 	{
 	  debug1("OpenPTY tries '%s'\n", PtyName);
 	  if ((f = open(PtyName, O_RDWR | O_NOCTTY)) == -1)
 	    continue;
 	  q[0] = *l;
 	  q[1] = *d;
+	  q[2] = *r;
 	  if (eff_uid && access(TtyName, R_OK | W_OK))
 	    {
 	      close(f);
@@ -396,6 +421,7 @@ char **ttyn;
 	  return f;
 	}
     }
+}
   return -1;
 }
 #endif
